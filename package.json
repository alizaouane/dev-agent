{
  "name": "dev-agent",
  "version": "0.3.0",
  "description": "Portable agentic feature development system. Claude Code plugin + reusable GitHub workflows + per-repo config schema.",
  "private": true,
  "type": "module",
  "workspaces": [
    "dashboard"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "cost-watchdog": "tsx lib/cli/cost-watchdog.ts",
    "events-scrape": "tsx lib/cli/events-scrape.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@octokit/rest": "^21.0.0",
    "deepmerge": "^4.3.1",
    "fast-xml-parser": "^5.7.2",
    "handlebars": "^4.7.8",
    "js-yaml": "^4.1.0",
    "minimatch": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
